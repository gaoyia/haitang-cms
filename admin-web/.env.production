VITE_ENV=production
VITE_WEB_TITLE=海棠 CMS
VITE_WEB_EN_TITLE=Haitang CMS
VITE_LOGIN_TITLE=海棠 CMS 管理平台
VITE_LOGIN_EN_TITLE=Haitang CMS Platform
# 生产环境 API 与页面同源，留空表示相对根路径
VITE_WEB_BASE_API=
VITE_ROUTER_MODE=history
VITE_DROP_CONSOLE=true
# 部署路径前缀（须与后端 ADMIN_WEB_PATH 一致，首尾含 /）
VITE_BASE=/haitang-cms-admin/
# 构建产物输出目录（相对 admin-web 根目录）
VITE_BUILD_OUT_DIR=../static/haitang-cms-admin
