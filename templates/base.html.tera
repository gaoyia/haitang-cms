<!DOCTYPE html>
<html lang="{{ html_lang }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ title }}{% endblock title %} - {{ site_name }}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/static/resources/css/site.css">
    <link rel="alternate" type="application/rss+xml" title="{{ site_name }} RSS" href="{{ locale_prefix }}/rss">
    {% block extra_head %}{% endblock extra_head %}
</head>
<body>
    <header class="site-header">
        <div class="site-header-inner">
            <div class="site-header-start">
                <a class="site-brand" href="{{ locale_prefix }}/">
                    <img class="site-brand-mark" src="/static/resources/logo.svg" alt="">
                    <span class="site-brand-name">{{ site_name }}</span>
                </a>
                <nav class="site-nav" aria-label="{% if lang == 'en-us' %}Main navigation{% else %}主导航{% endif %}">
                    {% for item in header_menus %}
                    <a href="{{ item.path }}"{% if current_path == item.path %} class="active"{% endif %}>{{ item.title }}</a>
                    {% endfor %}
                </nav>
            </div>
            <div class="site-header-aside">
                <div class="site-lang-switch" aria-label="{% if lang == 'en-us' %}Language{% else %}语言切换{% endif %}">
                    {% for link in locale_links %}
                    {% if not loop.first %}<span class="site-lang-sep" aria-hidden="true">/</span>{% endif %}
                    <a href="{{ link.url }}"{% if link.active %} class="active"{% endif %}>{{ link.label }}</a>
                    {% endfor %}
                </div>
                <a class="site-header-link" href="{{ locale_prefix }}/rss">RSS</a>
            </div>
        </div>
    </header>

    <main class="site-main">
        {% block content %}{% endblock content %}
    </main>

    <footer class="site-footer">
        <div class="site-footer-inner">
            <div class="site-footer-start">
                <a class="site-footer-brand" href="{{ locale_prefix }}/">
                    <img class="site-footer-mark" src="/static/resources/logo.svg" alt="">
                    <span class="site-footer-name">{{ site_name }}</span>
                </a>
                <p class="site-footer-tagline">
                    {% if lang == "en-us" %}
                    Structured content, elegant delivery.
                    {% else %}
                    结构化内容，优雅呈现。
                    {% endif %}
                </p>
            </div>
            {% if footer_menus %}
            <nav class="site-footer-nav" aria-label="{% if lang == 'en-us' %}Footer navigation{% else %}页脚导航{% endif %}">
                {% for item in footer_menus %}
                <a href="{{ item.path }}"{% if current_path == item.path %} class="active"{% endif %}>{{ item.title }}</a>
                {% endfor %}
            </nav>
            {% endif %}
        </div>
        <div class="site-footer-bottom">
            <p class="footer-copy">
                {{ site_copyright }}
                {% if site_icp %}
                <span class="footer-copy-sep" aria-hidden="true">·</span>
                <a href="https://beian.miit.gov.cn/" target="_blank" rel="noopener">{{ site_icp }}</a>
                {% endif %}
            </p>
        </div>
    </footer>

    <script src="/static/resources/js/jquery-4.0.0.min.js"></script>
    {% block scripts %}{% endblock scripts %}
</body>
</html>
